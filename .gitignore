# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# secrets & credentials (never commit)
secrets/
.secrets/
*.secret
*.secrets
secrets.json
credentials.json
*.key
*.keystore
*.jks
*.p12
*.pfx
*.cer
*.crt
id_rsa
id_rsa.*
id_ed25519
id_ed25519.*
*.gpg
*.asc
.aws/
.azure/
.gcp/
gcp-key*.json
service-account*.json
*.token
.netrc
auth.json

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files (allow example/template files only)
.env
.env.*
.env*.local
!.env.example
!.env.sample
!.env.template

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
